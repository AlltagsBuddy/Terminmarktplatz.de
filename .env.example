FLASK_ENV=production
SECRET_KEY=change_this_please_a_long_random_string
# PostgreSQL (Render Add-on):
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/terminmarktplatz
# SQLite mit persistentem Disk (Render: Disk unter /data mounten):
# DATABASE_URL=sqlite:////data/terminmarktplatz.db
# DATA_DIR=/data
DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/terminmarktplatz
JWT_ISS=terminmarktplatz
JWT_AUD=terminmarktplatz_client
# Login-Session: ohne „Angemeldet bleiben“ (Std.: 8 h); mit Checkbox (Std.: 30 Tage)
SESSION_HOURS=8
SESSION_REMEMBER_DAYS=30
MAIL_FROM=no-reply@terminmarktplatz.de
MAIL_PROVIDER=console # console | postmark
POSTMARK_TOKEN= # if MAIL_PROVIDER=postmark, paste server token
BASE_URL=https://api.terminmarktplatz.de

# CopeCart (optional, falls CopeCart statt Stripe für Pakete genutzt wird)
COPECART_PROFI_URL=https://copecart.com/products/a06e5188/checkout